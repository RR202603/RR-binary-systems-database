$ ------------------------------------------------------------------------------
$ Binary system
$
$ From from J. Korb 2004 (included in LB Vol. 5)
$
$ J. Korb, unpublished, GTT, 2004.
$
$ Checked against LB. Checked at 6000 K.
$
$ Unary Te has changed considerably since 91Din. 04Kor and lb5-v2 uses the
$ original 91Din Te unary data and not the current 95Dav data. Using the
$ current Te unary data results in changes in invariant equilibria in the
$ Te-rich part of the system. The eutectic is at 534.6 K instead of 553.1 K.
$
$ AgTe (prototype AgTe, oP32, Pnma, empressite) is considered metastable.
$
$ The Ag5Te3 phase (in particular) has mighty strange temperature intervals;
$ a series of slightly different, constant heat capacities.
$
$ The original, very low, maximum temperatures for the Gibbs energy
$ expressions have been removed.
$
 PAR  G(LIQUID,AG2TE),,                 -26634.9+515.194*T
             -104.6*T*LN(T);,,                                        N 04Kor !
 PAR  L(LIQUID,AG,TE;0),,               +2691.56+81.3977*T;,,         N 04Kor !
 PAR  L(LIQUID,AG,AG2TE;0),,            +18174.5+2.6954*T;,,          N 04Kor !
 PAR  L(LIQUID,AG,AG2TE;1),,            +3465.35;,,                   N 04Kor !
 PAR  L(LIQUID,AG2TE,TE;0),,            -28769.9-0.540139*T;,,        N 04Kor !
 PAR  L(LIQUID,AG2TE,TE;1),,            +15294.3;,,                   N 04Kor !
$
 PAR  G(AG2TE,AG:TE),,                  +GAG2TE;,,                    N 04Kor !
 PAR  G(AG19TE10,AG:TE),,               +GAG19TE;,,                   N 04Kor !
 PAR  G(AG5TE3,AG:TE),,                 +GAG5TE3;,,                   N 04Kor !
$
 PAR  G(GAS,AG2TE),,                    +FAG2TE+RTLNP;,,              N 00SGT !
 PAR  G(GAS,AGTE),,                     +FAGTE+RTLNP;,,               N 00SGT !
$
 FUNCTION GAG2TE    298.15  -57410.3+251.107*T-56.29*T*LN(T)-0.0481*T**2;
