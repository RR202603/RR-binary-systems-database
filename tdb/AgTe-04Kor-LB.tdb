       +7.014945E-05*T**2-6.05461833E-09*T**3+4031.7135*T**(-1);
      4100.00  Y  +243248.852+91.8458715*T-36.204*T*LN(T)
       +0.002972594*T**2-1.0817135E-07*T**3+15123625*T**(-1);
      8200.00  Y  +1054861.92-1266.75624*T+114.8787*T*LN(T)
       -0.00957561*T**2+8.79506333E-08*T**3-8.057185E+08*T**(-1);
     10000.00  N !
$ Ag2 (g) :
 FUNCTION FAG2      298.15   +396494.901-7.11759798*T-37.40575*T*LN(T)
       -3.6454985E-06*T**2+2.40071E-10*T**3+24860.28*T**(-1);
      3000.00  N !
$ ------------------------------------------------------------------------------
$ Te
$
$ HEXAGONAL_A8 and LIQUID revised in unary 3.0
$
$ Original 91Din for Te.
$
 PAR  G(HEXAGONAL_A8,TE),,              +GHSERTE;                2000 N 91Din !
 PAR  G(LIQUID,TE),,                    +GLIQTE;                 2000 N 91Din !
$
 PAR  G(GAS,TE),,                       +FTE+RTLNP;,,                 N 00SGT !
 PAR  G(GAS,TE2),,                      +FTE2+RTLNP;,,                N 00SGT !
 PAR  G(GAS,TE3),,                      +FTE3+RTLNP;,,                N 00SGT !
 PAR  G(GAS,TE4),,                      +FTE4+RTLNP;,,                N 00SGT !
 PAR  G(GAS,TE5),,                      +FTE5+RTLNP;,,                N 00SGT !
 PAR  G(GAS,TE6),,                      +FTE6+RTLNP;,,                N 00SGT !
 PAR  G(GAS,TE7),,                      +FTE7+RTLNP;,,                N 00SGT !
$
