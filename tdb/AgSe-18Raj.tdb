$ ------------------------------------------------------------------------------
$ Binary system
$
$ V.B. Rajkumar, S.-W. Chen, Calphad, 63, 51-60(2018).
$
$ Checked against paper and author's tdb. Checked at 6000 K.
$
$ The modelling of the liquid phase is strange. There are associates, but
$ interactions (too many of them) are only between Ag and Se. The paper also
$ includes a liquid without associates, but with even more interaction
$ parameters.
$
 PAR  G(LIQUID,AG2SE),,                 +2*GLIQAG+GLIQSE-36242;,,     N 18Raj !
 PAR  L(LIQUID,AG,SE;0),,               -43272;,,                     N 18Raj !
 PAR  L(LIQUID,AG,SE;1),,               -71134;,,                     N 18Raj !
 PAR  L(LIQUID,AG,SE;2),,               -42086;,,                     N 18Raj !
 PAR  L(LIQUID,AG,SE;3),,               +72325;,,                     N 18Raj !
 PAR  L(LIQUID,AG,SE;4),,               +384124;,,                    N 18Raj !
 PAR  L(LIQUID,AG,SE;5),,               +312668+49.15*T;,,            N 18Raj !
$
 PAR  G(AG2SE_ALPHA,AG:SE),,            +2*GHSERAG+GHSERSE
             -51699+36.41*T-6.06*T*LN(T);,,                           N 18Raj !
 PAR  G(AG2SE_ALPHA,SE:AG),,            +2*GHSERAG+GHSERSE
             +81699-36.41*T+6.06*T*LN(T);,,                           N 18Raj !
 PAR  L(AG2SE_ALPHA,AG,SE:SE;0),,       +91500;,,                     N 18Raj !
 PAR  L(AG2SE_ALPHA,AG:AG,SE;0),,       +25400;,,                     N 18Raj !
$
 PAR  G(AG2SE_BETA,AG:SE),,             +2*GHSERAG+GHSERSE
             -42414-22.89*T;,,                                        N 18Raj !
 PAR  G(AG2SE_BETA,SE:AG),,             +2*GHSERSE+GHSERAG
             +72414+22.89*T;,,                                        N 18Raj !
 PAR  L(AG2SE_BETA,AG,SE:SE;0),,        +78600;,,                     N 18Raj !
 PAR  L(AG2SE_BETA,AG:AG,SE;0),,        +20400;,,                     N 18Raj !
