$
$ Database for Al-Fe from W. Zheng et al. 2017.
$
$ W. Zheng, S. He, M. Selleby, Y. He, L. Li, X.-G. Lu, J. Agren,
$ Calphad, 58, 34-49(2017).
$
$ Dataset created 2019.05.19 by Bengt Hallstedt.
$ 2020.01.21: Modified for use with GES6.
$ 2020.01.21: Minor modifications (A2/B2/BCC_4SL).
$
$ Modified from 09Sun. For the B2_BCC, BCC_4SL and FCC_4SL phases the
$ bond exchange energies UB1ALFE (very slightly) and U1FALFE were modified.
$ Additionally, the L1 and L2 interactions for B2_BCC were changed. Other
$ parameters for these phases were kept unchanged.
$
$ The bcc-2sl and bcc-4sl models produce somewhat different results.
$
$ This datasets contains 4SL fcc (FCC_4SL + A1_FCC) and bcc (BCC_4SL + A2_4SL)
$ and 2SL bcc (B2_BCC + A2_BCC). Option F and B are used.
$
$ ------------------------------------------------------------------------------
 TEMP-LIM 298.15 6000.00 !
$
$ELEMENT NAME  REF. STATE               ATOMIC MASS H298-H0    S298    !
$
 ELEMENT VA   VACUUM                      0.0          0.0      0.0    ! 
 ELEMENT AL   FCC_A1                     26.98154   4540.      28.30   ! 
 ELEMENT FE   BCC_A2                     55.847     4489.0     27.2797 ! 
$ ------------------------------------------------------------------------------
$ Phase definitions
$
 PHASE LIQUID:L % 1 1 !
 CONST LIQUID:L : AL FE : !
$
$ Fcc (cF4, Fm-3m) and MeX (cF8, Fm-3m)
$
 PHASE FCC_A1 %A 2 1 1 !
 CONST FCC_A1 : AL FE : VA : !
$
$ Disordered part of FCC_4SL, identical to FCC_A1
$
 PHASE A1_FCC %A 2 1 1 !
 CONST A1_FCC : AL FE : VA : !
$
$ Prototype AuCu (L1_0, tP4, P4/mmm) and AuCu3 (L1_2, cP4, Pm-3m)
$
 PHASE FCC_4SL:F %AY 5 0.25 0.25 0.25 0.25 1 !
 CONST FCC_4SL:F : AL FE : AL FE : AL FE : AL% FE : VA :  !
$
$ Bcc (cI2, Im-3m)
$
 PHASE BCC_A2 %B 2 1 3 !
 CONST BCC_A2 : AL FE : VA : !
$
$ Disordered part of B2_BCC and BCC_4SL, identical to BCC_A2
$
 PHASE A2_BCC %B 2 1 3 !
 CONST A2_BCC : AL FE : VA : !
$
$ Prototype CsCl (cP2, Pm-3m)
$
 PHASE B2_BCC %BO 3 0.5 0.5 3 !
 CONST B2_BCC : AL% FE : AL FE% : VA : !
$
$ Prototype CsCl (B2, cP2, Pm-3m), NaTl (B32, cF16, Fd-3m),
$ BiF3 (D0_3, cF16, Fm-3m), AlCu2Mn (L2_1, cF16)
$
 PHASE BCC_4SL:B %BZ 5 0.25 0.25 0.25 0.25 3 !
 CONST BCC_4SL:B : AL FE% : AL FE% : AL FE% : AL% FE : VA% :  !
$
$ Hcp (hP2, P6_3/mmc) and Me2X (NiAs-type, hP4, P6_3/mmc, B8_1)
$
 PHASE HCP_A3 %A 2 1 0.5 !
 CONST HCP_A3 : AL FE : VA : !
$
$ Prototype Al13Fe4 (mC102, C2/m)
$
 PHASE AL13FE4 % 3 0.6275 0.235 0.1375 !
 CONST AL13FE4 : AL : FE : AL VA : !
$
$ Prototype Al5Fe2 (oC24, Cmcm)
$ Al5Fe2 does not have the Al5Co2 (D8_11) structure
$
 PHASE AL5FE2 % 2 5 2 !
 CONST AL5FE2 : AL : FE : !
$
$ Prototype Al2Fe (aP18, P1)
$
 PHASE AL2FE % 2 2 1 !
 CONST AL2FE : AL : FE : !
$
$ Prototype Cu8Zn5 (cI52, I-43m)
$
 PHASE AL8FE5_D82 % 2 8 5 !
 CONST AL8FE5_D82 : AL FE : AL FE : !
$ ------------------------------------------------------------------------------
$ Defaults
$
 DEFINE-SYSTEM-DEFAULT ELEMENT 2 !
 DEFAULT-COM DEFINE_SYSTEM_ELEMENT VA !
 DEFAULT-COM REJECT_PHASE BCC_A2 BCC_4SL FCC_A1 !
 TYPE-DEF % SEQ * !
 TYPE-DEF A GES AMEND_PHASE_DESCRIPTION @ MAGNETIC -3 0.28 !
 TYPE-DEF B GES AMEND_PHASE_DESCRIPTION @ MAGNETIC -1 0.4 !
 TYPE-DEF O GES AMEND_PHASE_DESCRIPTION B2_BCC DIS_PART A2_BCC !
 TYPE-DEF Y GES AMEND_PHASE_DESCRIPTION FCC_4SL DIS_PART A1_FCC !
 TYPE-DEF Z GES AMEND_PHASE_DESCRIPTION BCC_4SL DIS_PART A2_BCC !
 FUNCTION ZERO      298.15  0;                                         6000 N !
 FUNCTION UN_ASS    298.15  0;                                         6000 N !
 FUNCTION R         298.15  +8.31451;                                  6000 N !
$ ------------------------------------------------------------------------------
$ Element data
$ ------------------------------------------------------------------------------
$ Al
$
$ BCT_A5 and DIAMOND_A4 added in unary 3.0
$
 PAR  G(FCC_A1,AL:VA),,                 +GHSERAL;                2900 N 91Din !
 PAR  G(A1_FCC,AL:VA),,                 +GHSERAL;                2900 N 91Din !
 PAR  G(BCC_A2,AL:VA),,                 +GHSERAL+10083-4.813*T;  2900 N 91Din !
 PAR  G(A2_BCC,AL:VA),,                 +GHSERAL+10083-4.813*T;  2900 N 91Din !
 PAR  G(HCP_A3,AL:VA),,                 +GHSERAL+5481-1.8*T;     2900 N 91Din !
$PAR  G(CBCC_A12,AL:VA),,               +GHSERAL
$            +10083.4-4.813*T;                                   2900 N 91Din !
$PAR  G(CUB_A13,AL:VA),,                +GHSERAL
$            +10920.44-4.8116*T;                                 2900 N 91Din !
$PAR  G(BCT_A5,AL),,                    +GHSERAL+10083-4.813*T;  2900 N SGCOST !
$PAR  G(DIAMOND_A4,AL),,                +GHSERAL+30*T;           2900 N SGCOST !
 PAR  G(LIQUID,AL),,                    +GLIQAL;                 2900 N 91Din !
$
 PAR  G(AL8FE5_D82,AL:AL),,             +13*GBCCAL;,,                 N 09Sun !
$
 FUNCTION GHSERAL   298.15  -7976.15+137.093038*T-24.3671976*T*LN(T)
       -0.001884662*T**2-8.77664E-07*T**3+74092*T**(-1);
       700.00  Y  -11276.24+223.048446*T-38.5844296*T*LN(T)
       +0.018531982*T**2 -5.764227E-06*T**3+74092*T**(-1);
       933.47  Y  -11278.361+188.684136*T-31.748192*T*LN(T)
       -1.230622E+28*T**(-9);
      2900.00  N !
 FUNCTION GLIQAL    298.15  +11005.045-11.84185*T+GHSERAL+7.9337E-20*T**7;
       933.47  Y  -795.991+177.430209*T-31.748192*T*LN(T);
      2900.00  N !
 FUNCTION GBCCAL    298.15  +GHSERAL+10083-4.813*T;                    2900 N !
$ ------------------------------------------------------------------------------
$ Fe
$
$ ORTHORHOMBIC_A20 and TETRAGONAL_U added im unary 4.1
$
 PAR  G(BCC_A2,FE:VA),,                 +GHSERFE;,,                   N 91Din !
 PAR  TC(BCC_A2,FE:VA),,                 1043.00;,,                   N 91Din !
 PAR  BM(BCC_A2,FE:VA),,                    2.22;,,                   N 91Din !
 PAR  G(A2_BCC,FE:VA),,                 +GHSERFE;,,                   N 91Din !
 PAR  TC(A2_BCC,FE:VA),,                 1043.00;,,                   N 91Din !
 PAR  BM(A2_BCC,FE:VA),,                    2.22;,,                   N 91Din !
 PAR  G(FCC_A1,FE:VA),,                 +GFCCFE;,,                    N 91Din !
 PAR  TC(FCC_A1,FE:VA),,                 -201.00;,,                   N 91Din !
 PAR  BM(FCC_A1,FE:VA),,                   -2.10;,,                   N 91Din !
 PAR  G(A1_FCC,FE:VA),,                 +GFCCFE;,,                    N 91Din !
 PAR  TC(A1_FCC,FE:VA),,                 -201.00;,,                   N 91Din !
 PAR  BM(A1_FCC,FE:VA),,                   -2.10;,,                   N 91Din !
 PAR  G(HCP_A3,FE:VA),,                 +GHCPFE;,,                    N 91Din !
$PAR  G(CBCC_A12,FE:VA),,               +GHSERFE+4745;,,              N 91Din !
$PAR  G(CUB_A13,FE:VA),,                +GHSERFE+3745;,,              N 91Din !
$PAR  G(ORTHORHOMBIC_A20,FE),,          +GHSERFE+5000;,,              N 99SGUN !
$PAR  G(TETRAGONAL_U,FE),,              +GHSERFE+5000;,,              N 99SGUN !
 PAR  G(LIQUID,FE),,                    +GLIQFE;,,                    N 91Din !
$
 PAR  G(AL8FE5_D82,FE:FE),,             +13*GHSERFE+13000;,,          N 09Sun !
$
 FUNCTION GHSERFE   298.15  +1225.7+124.134*T-23.5143*T*LN(T)
       -0.00439752*T**2-5.8927E-08*T**3+77359*T**(-1);
      1811.00  Y  -25383.581+299.31255*T-46*T*LN(T)+2.29603E+31*T**(-9);
      6000.00  N !
 FUNCTION GFCCFE    298.15  -1462.4+8.282*T-1.15*T*LN(T)
       +6.4E-04*T**2+GHSERFE;
      1811.00  Y  -1713.815+0.940009*T+GHSERFE+4.9251E+30*T**(-9);
      6000.00  N !
 FUNCTION GHCPFE    298.15  -3705.78+12.591*T-1.15*T*LN(T)
       +6.4E-04*T**2+GHSERFE;
      1811.00  Y  -3957.195+5.249009*T+GHSERFE+4.9251E+30*T**(-9);
      6000.00  N !
 FUNCTION GLIQFE    298.15  +12040.17-6.55843*T+GHSERFE-3.67516E-21*T**7;
      1811.00  Y  -10838.83+291.302*T-46*T*LN(T);
      6000.00  N !
$ ------------------------------------------------------------------------------
$ Binary system
$
$ W. Zheng, S. He, M. Selleby, Y. He, L. Li, X.-G. Lu, J. Agren,
$ Calphad, 58, 34-49(2017).
$
$ Checked against paper and author's tdb. Checked at 6000 K.
$
$ Modified from 09Sun. For the B2_BCC, BCC_4SL and FCC_4SL phases the
$ bond exchange energies UB1ALFE (very slightly) and U1FALFE were modified.
$ Additionally, the L1 and L2 interactions for B2_BCC were changed. Other
$ parameters for these phases were kept unchanged.
$
$ This datasets contains 4SL fcc (FCC_4SL + A1_FCC) and bcc (BCC_4SL + A2_4SL)
$ and 2SL bcc (B2_BCC + A2_BCC). Option F and B are used.
$
 PAR  L(LIQUID,AL,FE;0),,               -81930+16.03*T;,,             N 17Zhe !
 PAR  L(LIQUID,AL,FE;1),,               -15100+9.38*T;,,              N 17Zhe !
$
 PAR  L(FCC_A1,AL,FE:VA;0),,            -100041+25.14*T;,,            N 17Zhe !
 PAR  L(FCC_A1,AL,FE:VA;1),,            +33159-11.86*T;,,             N 17Zhe !
 PAR  L(FCC_A1,AL,FE:VA;2),,            +32200-17*T;,,                N 09Sun !
$
 PAR  L(A1_FCC,AL,FE:VA;0),,            -100041+25.14*T;,,            N 17Zhe !
 PAR  L(A1_FCC,AL,FE:VA;1),,            +33159-11.86*T;,,             N 17Zhe !
 PAR  L(A1_FCC,AL,FE:VA;2),,            +32200-17*T;,,                N 09Sun !
$
 PAR  G(FCC_4SL,FE:AL:AL:AL:VA),,       +GFAL3FE;,,                   N 17Zhe !
 PAR  G(FCC_4SL,FE:FE:AL:AL:VA),,       +GFAL2FE2;,,                  N 17Zhe !
 PAR  G(FCC_4SL,FE:FE:FE:AL:VA),,       +GFALFE3;,,                   N 17Zhe !
 PAR  L(FCC_4SL,AL,FE:*:*:*:VA;0),,     +L0FALFE;,,                   N 17Zhe !
 PAR  L(FCC_4SL,AL,FE:AL,FE:*:*:VA;0),, +SFALFE;,,                    N 17Zhe !
$
 PAR  L(BCC_A2,AL,FE:VA;0),,            -122360+31.6*T;,,             N 17Zhe !
 PAR  L(BCC_A2,AL,FE:VA;1),,            +2945.2;,,                    N 93Sei !
 PAR  L(BCC_A2,AL,FE:VA;2),,            +495;,,                       N 17Zhe !
 PAR  TC(BCC_A2,AL,FE:VA;0),,            -438;,,                      N 09Sun !
 PAR  TC(BCC_A2,AL,FE:VA;1),,           -1720;,,                      N 09Sun !
$
 PAR  L(A2_BCC,AL,FE:VA;0),,            -122360+31.6*T;,,             N 17Zhe !
 PAR  L(A2_BCC,AL,FE:VA;1),,            +2945.2;,,                    N 93Sei !
 PAR  L(A2_BCC,AL,FE:VA;2),,            +495;,,                       N 17Zhe !
 PAR  TC(A2_BCC,AL,FE:VA;0),,            -438;,,                      N 09Sun !
 PAR  TC(A2_BCC,AL,FE:VA;1),,           -1720;,,                      N 09Sun !
$
 PAR  G(B2_BCC,AL:FE:VA),,              +GB2ALFE;,,                   N 17Zhe !
 PAR  G(B2_BCC,FE:AL:VA),,              +GB2ALFE;,,                   N 17Zhe !
 PAR  L(B2_BCC,AL,FE:AL:VA;0),,         +5600;,,                      N 09Sun !
 PAR  L(B2_BCC,AL:AL,FE:VA;0),,         +5600;,,                      N 09Sun !
 PAR  L(B2_BCC,FE:AL,FE:VA;0),,         -1400+2.4*T;,,                N 09Sun !
 PAR  L(B2_BCC,AL,FE:FE:VA;0),,         -1400+2.4*T;,,                N 09Sun !
 PAR  L(B2_BCC,AL,FE:*:VA;0),,          +3*UB2ALFE;,,                 N 09Sun !
 PAR  L(B2_BCC,*:AL,FE:VA;0),,          +3*UB2ALFE;,,                 N 09Sun !
 PAR  L(B2_BCC,AL,FE:*:VA;1),,          +120;,,                       N 17Zhe !
 PAR  L(B2_BCC,*:AL,FE:VA;1),,          +120;,,                       N 17Zhe !
 PAR  L(B2_BCC,AL,FE:*:VA;2),,          -520;,,                       N 17Zhe !
 PAR  L(B2_BCC,*:AL,FE:VA;2),,          -520;,,                       N 17Zhe !
 PAR  L(B2_BCC,AL,FE:AL,FE:VA;0),,      -8400-4.8*T;,,                N 09Sun !
 PAR  TC(B2_BCC,FE:AL:VA),,             +2*UTCBALFE;,,                N 09Sun !
 PAR  TC(B2_BCC,AL:FE:VA),,             +2*UTCBALFE;,,                N 09Sun !
 PAR  TC(B2_BCC,AL,FE:*:VA;0),,         -2*UTCBALFE;,,                N 09Sun !
 PAR  TC(B2_BCC,*:AL,FE:VA;0),,         -2*UTCBALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,FE:AL:VA),,             +2*UBMBALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,AL:FE:VA),,             +2*UBMBALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,AL,FE:*:VA;0),,         +2*BM0BALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,*:AL,FE:VA;0),,         +2*BM0BALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,AL,FE:*:VA;1),,         +2*BM1BALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,*:AL,FE:VA;1),,         +2*BM1BALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,AL,FE:*:VA;2),,         +2*BM2BALFE;,,                N 09Sun !
 PAR  BM(B2_BCC,*:AL,FE:VA;2),,         +2*BM2BALFE;,,                N 09Sun !
$
 PAR  G(BCC_4SL,AL:AL:AL:FE:VA),,       +GBAL3FE;,,                   N 17Zhe !
 PAR  G(BCC_4SL,AL:AL:FE:FE:VA),,       +GB2ALFE;,,                   N 17Zhe !
 PAR  G(BCC_4SL,AL:FE:AL:FE:VA),,       +GB32ALFE;,,                  N 17Zhe !
 PAR  G(BCC_4SL,AL:FE:FE:FE:VA),,       +GBALFE3;,,                   N 17Zhe !
 PAR  L(BCC_4SL,AL,FE:*:*:*:VA;0),,     +L0BALFE;,,                   N 09Sun !
 PAR  L(BCC_4SL,AL,FE:*:*:*:VA;1),,     +L1BALFE;,,                   N 09Sun !
 PAR  L(BCC_4SL,AL,FE:*:*:*:VA;2),,     +L2BALFE;,,                   N 09Sun !
 PAR  TC(BCC_4SL,AL:AL:AL:FE:VA),,      +UTCBALFE;,,                  N 09Sun !
 PAR  TC(BCC_4SL,AL:AL:FE:FE:VA),,      +2*UTCBALFE;,,                N 09Sun !
 PAR  TC(BCC_4SL,AL:FE:AL:FE:VA),,      +UTCBALFE;,,                  N 09Sun !
 PAR  TC(BCC_4SL,AL:FE:FE:FE:VA),,      +UTCBALFE;,,                  N 09Sun !
 PAR  TC(BCC_4SL,AL,FE:*:*:*:VA;0),,    -UTCBALFE;,,                  N 09Sun !
 PAR  BM(BCC_4SL,AL:AL:AL:FE:VA),,      +UBMBALFE;,,                  N 09Sun !
 PAR  BM(BCC_4SL,AL:AL:FE:FE:VA),,      +2*UBMBALFE;,,                N 09Sun !
 PAR  BM(BCC_4SL,AL:FE:AL:FE:VA),,      +UBMBALFE;,,                  N 09Sun !
 PAR  BM(BCC_4SL,AL:FE:FE:FE:VA),,      +UBMBALFE;,,                  N 09Sun !
 PAR  BM(BCC_4SL,AL,FE:*:*:*:VA;0),,    +BM0BALFE;,,                  N 09Sun !
 PAR  BM(BCC_4SL,AL,FE:*:*:*:VA;1),,    +BM1BALFE;,,                  N 09Sun !
 PAR  BM(BCC_4SL,AL,FE:*:*:*:VA;2),,    +BM2BALFE;,,                  N 09Sun !
$
 PAR  G(AL13FE4,AL:FE:AL),,             +0.765*GHSERAL+0.235*GHSERFE
             -30680+7.44*T;,,                                         N 17Zhe !
 PAR  G(AL13FE4,AL:FE:VA),,             +0.6275*GHSERAL+0.235*GHSERFE
             -28100+7.44*T;,,                                         N 17Zhe !
$
 PAR  G(AL5FE2,AL:FE),,                 +5*GHSERAL+2*GHSERFE
             -235600+54.3*T;,,                                        N 17Zhe !
 PAR  G(AL2FE,AL:FE),,                  +2*GHSERAL+GHSERFE
             -103900+23*T;,,                                          N 17Zhe !
$
 PAR  G(AL8FE5_D82,AL:FE),,             +8*GBCCAL+5*GHSERFE
             -394000+36.2*T;,,                                        N 17Zhe !
 PAR  G(AL8FE5_D82,FE:AL),,             +8*GHSERFE+5*GBCCAL
             +200000+36.2*T;,,                                        N 17Zhe !
 PAR  L(AL8FE5_D82,AL,FE:FE;0),,        -174000;,,                    N 09Sun !
 PAR  L(AL8FE5_D82,AL:AL,FE;0),,        -120000;,,                    N 17Zhe !
$
$ metastable
$
$PAR  L(HCP_A3,AL,FE:VA;0),,            -106903+20*T;,,               N 97Jan !
 PAR  L(HCP_A3,AL,FE:VA;0),,            -100000+20*T;,,               N 13Lin !
$PAR  L(CBCC_A12,AL,FE:VA;0),,          +ZERO;,,                      N 97Jan !
$PAR  L(CUB_A13,AL,FE:VA;0),,           -117900+23.2*T;,,             N 13Lin !
$PAR  L(CUB_A13,AL,FE:VA;1),,           +64700-44*T;,,                N 13Lin !
