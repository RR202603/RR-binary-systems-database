$
 ASSESSED_SYSTEM
  AL-FE(TDB -* +LIQ +FCC_A1 +BCC_4SL A2_BCC +AL13FE4 +AL5FE2 +AL2FE +AL8FE5_D82 
  ;P3 TMM:300/2000 STP:.5/1000/1 STP:.99/1500/-1) !
