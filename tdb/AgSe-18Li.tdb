       +7.014945E-05*T**2-6.05461833E-09*T**3+4031.7135*T**(-1);
      4100.00  Y  +243248.852+91.8458715*T-36.204*T*LN(T)
       +0.002972594*T**2-1.0817135E-07*T**3+15123625*T**(-1);
      8200.00  Y  +1054861.92-1266.75624*T+114.8787*T*LN(T)
       -0.00957561*T**2+8.79506333E-08*T**3-8.057185E+08*T**(-1);
