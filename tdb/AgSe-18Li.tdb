       -6.186E-04*T**2+4.43333333E-09*T**3+17300*T**(-1);
      2000.00  Y  +363212.723+124.274363*T-53.368*T*LN(T)
       +0.00202825*T**2+7.245E-09*T**3+11269075*T**(-1);
      4100.00  Y  +359870.325+178.339145*T-60.626*T*LN(T)
       +0.0042801*T**2-9.68483333E-08*T**3+5303090*T**(-1);
      6000.00  N !
$ ------------------------------------------------------------------------------
$ Se
$
$ The origin of the function GBCCSE is unknown. It is used by 18Li and they
$ cite 91Din, which is incorrect.
$
 PAR  G(HEXAGONAL_A8,SE),,              +GHSERSE;                1000 N 91Din !
$PAR  G(LIQUID,SE),,                    +GLIQSE;                 1000 N 91Din !
$
 PAR  G(ION,SE),,                       +GLIQSE;                 1000 N 91Din !
 PAR  G(AG2SE_ALPHA,VA:SE),,            +GHSERSE+22869;,,             N 18Li !
 PAR  G(AG2SE_BETA,VA:VA:VA:VA:SE),,    +GBCCSE;,,                    N 18Li !
$
 PAR  G(GAS,SE),,                       +F15139T+RTLNP;,,             N 97SUB !
 PAR  G(GAS,SE2),,                      +F15179T+RTLNP;,,             N 97SUB !
 PAR  G(GAS,SE3),,                      +F15186T+RTLNP;,,             N 97SUB !
 PAR  G(GAS,SE4),,                      +F15188T+RTLNP;,,             N 97SUB !
 PAR  G(GAS,SE5),,                      +F15190T+RTLNP;,,             N 97SUB !
 PAR  G(GAS,SE6),,                      +F15192T+RTLNP;,,             N 97SUB !
 PAR  G(GAS,SE7),,                      +F15194T+RTLNP;,,             N 97SUB !
 PAR  G(GAS,SE8),,                      +F15196T+RTLNP;,,             N 97SUB !
$
