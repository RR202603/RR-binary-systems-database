$
$ Database for Ag-Ca from P.-Y. Chevalier and E. Fischer 1996
$ (included in LB Vol. 5)
$
$ P.-Y. Chevalier, E. Fischer, unpublished, Thermodata, 1996.
$
$ Dataset created 2013.05.27 by Bengt Hallstedt.
$ 2020.12.20: Modified for use with GES6.
$
$ This dataset produces a beautiful inverse phase diagram; all intermetallic
$ phases have an inverse stability range starting above 4000 K.
$
$ ------------------------------------------------------------------------------
 TEMP-LIM 298.15 6000.00 !
$
$ELEMENT NAME  REF. STATE               ATOMIC MASS H298-H0    S298    !
$
 ELEMENT VA   VACUUM                      0.0          0.0      0.0    ! 
 ELEMENT AG   FCC_A1                    107.8682    5745.      42.55   ! 
 ELEMENT CA   FCC_A1                     40.08      5736.0     41.588  ! 
$ ------------------------------------------------------------------------------
$ Phase definitions
$
 PHASE LIQUID:L % 1 1 !
 CONST LIQUID:L : AG CA : !
$
$ Fcc (cF4, Fm-3m) and MeX (cF8, Fm-3m)
$
 PHASE FCC_A1 %A 2 1 1 !
 CONST FCC_A1 : AG% CA% : VA : !
$
$ Bcc (cI2, Im-3m)
$
 PHASE BCC_A2 %B 2 1 3 !
 CONST BCC_A2 : AG CA% : VA : !
$
$ Hcp (hP2, P6_3/mmc) and Me2X (NiAs-type, hP4, P6_3/mmc, B8_1)
$
 PHASE HCP_A3 %A 2 1 0.5 !
 CONST HCP_A3 : AG CA : VA : !
$
$ Prototype AuBe5 (cF24, F-43m)
$
 PHASE AG9CA2_C15B % 2 9 2 !
 CONST AG9CA2_C15B : AG : CA : !
$
$ Prototype Ag7Yb2 (oC36, Cmcm)
$ hP18, P6_322 suggested in LB binary
$
 PHASE AG7CA2 % 2 7 2 !
 CONST AG7CA2 : AG : CA : !
$
$ Prototype Hg2K (oI12, Imma)
$
 PHASE AG2CA % 2 2 1 !
 CONST AG2CA : AG : CA : !
$
$ Prototype CrB (oC8, Cmcm)
$
 PHASE AGCA_B33 % 2 1 1 !
 CONST AGCA_B33 : AG : CA : !
$
$ Prototype Cr5B3 (tI32, I4/mcm)
$
 PHASE AG3CA5_D8L % 2 3 5 !
 CONST AG3CA5_D8L : AG : CA : !
$
$ Pearson oC16, Cmcm
$
 PHASE AGCA3 % 2 1 3 !
 CONST AGCA3 : AG : CA : !
$ ------------------------------------------------------------------------------
$ Defaults
$
 DEFINE-SYSTEM-DEFAULT ELEMENT 2 !
 DEFAULT-COM DEFINE_SYSTEM_ELEMENT VA !
 TYPE-DEF % SEQ * !
 TYPE-DEF A GES AMEND_PHASE_DESCRIPTION @ MAGNETIC -3 0.28 !
 TYPE-DEF B GES AMEND_PHASE_DESCRIPTION @ MAGNETIC -1 0.4 !
 FUNCTION ZERO      298.15  0;                                         6000 N !
 FUNCTION UN_ASS    298.15  0;                                         6000 N !
 FUNCTION R         298.15  +8.31451;                                  6000 N !
$ ------------------------------------------------------------------------------
$ Element data
$ ------------------------------------------------------------------------------
$ Ag
$
$ CUB_A13 added in unary 3.0
$ CUB_A13 revised in unary 4.1
$ BCT_A5 added in unary 4.1
$
 PAR  G(FCC_A1,AG:VA),,                 +GHSERAG;                3000 N 91Din !
 PAR  G(HCP_A3,AG:VA),,                 +GHSERAG+300+0.3*T;      3000 N 91Din !
 PAR  G(BCC_A2,AG:VA),,                 +GHSERAG+3400-1.05*T;    3000 N 91Din !
$PAR  G(CUB_A13,AG:VA),,                +GHSERAG+3400-1.05*T;    3000 N 95Lim !
$PAR  G(CUB_A13,AG:VA),,                +GHSERAG
$            +3765.6-1.8826*T;                                   3000 N 96SGUN !
$PAR  G(BCT_A5,AG),,                    +GHSERAG+4184.1;         3000 N 96Oh !
 PAR  G(LIQUID,AG),,                    +GLIQAG;                 3000 N 91Din !
$
 FUNCTION GHSERAG   298.15  -7209.512+118.202013*T-23.8463314*T*LN(T)
       -0.001790585*T**2-3.98587E-07*T**3-12011*T**(-1);
      1234.93  Y  -15095.252+190.266404*T-33.472*T*LN(T)+1.411773E+29*T**(-9);
      3000.00  N !
 FUNCTION GLIQAG    298.15  +11025.076-8.89102*T+GHSERAG-1.033905E-20*T**7;
      1234.93  Y  -3587.111+180.964656*T-33.472*T*LN(T);
      3000.00  N !
$ ------------------------------------------------------------------------------
$ Ca
$
$ FCC_A1, BCC_A2, HCP_A3 and LIQUID modified in unary 5.0
$ (upper T interval added + trailing decimals added)
$
 PAR  G(FCC_A1,CA:VA),,                 +GHSERCA;                3001 N 91Din !
 PAR  G(BCC_A2,CA:VA),,                 +GBCCCA;                 3001 N 91Din !
 PAR  G(HCP_A3,CA:VA),,                 +GHSERCA+500+0.7*T;      3001 N 91Din !
 PAR  G(LIQUID,CA),,                    +GLIQCA;                 3001 N 91Din !
$
 FUNCTION GHSERCA   298.15  -4955.062+72.794266*T-16.3138*T*LN(T)
       -0.01110455*T**2-133574*T**(-1);
      1115.00  Y  -107304.428+799.982066*T-114.2922467*T*LN(T)
       +0.023733814*T**2-1.2438E-06*T**3+18245540*T**(-1);
      3000.00  Y  -3703.12+192.63995*T-35.0*T*LN(T);
      3001.00  N !
 FUNCTION GBCCCA    298.15  -7020.852+142.970155*T-28.2541*T*LN(T)
       +0.0072326*T**2-4.500217E-06*T**3+60578*T**(-1);
       716.00  Y  +1640.475+1.999694*T-6.276*T*LN(T)
       -0.0161921*T**2-523000*T**(-1);
      1115.00  Y  -142331.096+1023.549046*T-143.8726979*T*LN(T)
       +0.032543127*T**2-1.704079E-06*T**3+25353771*T**(-1);
      3000.00  Y  +321.63+189.433057*T-35*T*LN(T);
      3001.00  N !
 FUNCTION GLIQCA    298.15  +10799.908-10.310466*T+GHSERCA;
       500.00  Y  +7838.856+18.2979*T-8.9874787*T*LN(T)
       -0.02266537*T**2+3.338303E-06*T**3-230193*T**(-1);
      1115.00  Y  -2654.938+188.9223*T-35*T*LN(T);
      3001.00  N !
$ ------------------------------------------------------------------------------
$ Binary system
$
$ From P.-Y. Chevalier and E. Fischer 1996 (included in LB Vol. 5)
$
$ P.-Y. Chevalier, E. Fischer, unpublished, Thermodata, 1996.
$
$ Checked against LB. Checked at 6000 K.
$
$ This dataset produces a beautiful inverse phase diagram; all intermetallic
$ phases have an inverse stability range starting above 4000 K.
$
 PAR  L(LIQUID,AG,CA;0),,               -86325.75;,,                  N 96Che !
 PAR  L(LIQUID,AG,CA;1),,               -19647.53;,,                  N 96Che !
$
 PAR  L(FCC_A1,AG,CA:VA;0),,            +50000;,,                     N 96Che !
 PAR  L(BCC_A2,AG,CA:VA;0),,            +UN_ASS;,,                    N !
$
 PAR  G(AG9CA2_C15B,AG:CA),,            -254402.39+1209.39513*T
             -247.244583*T*LN(T)-0.038324365*T**2-3.587283E-06*T**3
             -375247*T**(-1);,,                                       N 96Che !
 PAR  G(AG7CA2,AG:CA),,                 -234601.65+972.993663*T
             -199.55192*T*LN(T)-0.034743195*T**2-2.790109E-06*T**3
             -351225*T**(-1);,,                                       N 96Che !
 PAR  G(AG2CA,AG:CA),,                  -86326.77+309.195732*T
             -64.0064628*T*LN(T)-0.0146857*T**2-7.97174E-07*T**3
             -157596*T**(-1);,,                                       N 96Che !
 PAR  G(AGCA_B33,AG:CA),,               -62011.12+190.994999*T
             -40.1601314*T*LN(T)-0.012895135*T**2-3.98587E-07*T**3
             -145585*T**(-1);,,                                       N 96Che !
 PAR  G(AG3CA5_D8L,AG:CA),,             -213297.52+718.573529*T
             -153.107994*T*LN(T)-0.060894505*T**2-1.195761E-06*T**3
             -703903*T**(-1);,,                                       N 96Che !
 PAR  G(AGCA3,AG:CA),,                  -80292.88+336.583531*T
             -72.787731*T*LN(T)-0.035104235*T**2-3.98587E-07*T**3
             -412733*T**(-1);,,                                       N 96Che !
$
$ metastable
$
 PAR  L(HCP_A3,AG,CA:VA;0),,            +UN_ASS;,,                    N !
$ ------------------------------------------------------------------------------
$
 ASSESSED_SYSTEM
  AG-CA(TDB -* +LIQUID +FCC_A1 +BCC_A2 +AG9CA2_C15B +AG7CA2 +AG2CA +AGCA_B33
  +AG3CA5_D8L +AGCA3 ;G5 C_S:FCC_A1/CA:VA MAJ:FCC_A1/AG:VA ;P3 *) !
$
$
 LIST-OF-REFERENCE
 NUMBER  SOURCE
  Null   'Unknown source'
  Same   'Same or similar interaction as in the corresponding stable phase'
  COST   'COST 507 database'
  91Din  'A.T. Dinsdale, Calphad, 15, 317-425(1991).'
  95Lim  'S.S. Lim, P.L. Rossiter, J.W. Tibballs, Calphad, 19, 131-41(1995),
          SGTE unary database V.4.1, 1999; Ag'
  96Che  'P.-Y. Chevalier, E. Fischer, unpublished, Thermodata, 1996; Ag-Ca'
  96Oh   'C.-S. Oh, J.-H. Shim, B.-J. Lee, D.N. Lee,
          J. Alloys Compounds, 238, 155-66(1996),
          SGTE unary database V.4.1, 1999; Ag'
  96SGUN 'SGTE unary database V.3.0, 1996.'
!
